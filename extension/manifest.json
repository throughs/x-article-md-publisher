{
  "manifest_version": 3,
  "name": "X Article Markdown Publisher",
  "version": "2.0",
  "description": "Import Markdown articles into the X Articles editor with one click",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "https://x.com/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*/articles/edit/*", "https://x.com/compose/articles*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
